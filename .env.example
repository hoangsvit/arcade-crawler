# false: chỉ crawl và lưu dataset; true: publish Firebase Remote Config
PUBLISH_REMOTE_CONFIG=false

FIREBASE_REMOTE_CONFIG_KEY=arcade_milestones
FIREBASE_PROJECT_ID=your-project-id

# Dán toàn bộ service account JSON trên một dòng.
# Có thể bỏ trống khi PUBLISH_REMOTE_CONFIG=false.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com"}
